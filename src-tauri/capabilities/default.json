{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and secondary windows",
  "windows": ["main", "folio-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "store:default",
    "fs:default",
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "**" }]
    },
    "window-state:default"
  ]
}
